# ==========================================================
# CandidateOne
# Python / Flask .gitignore
# ==========================================================

# ----------------------------------------------------------
# Python
# ----------------------------------------------------------

__pycache__/
*.py[cod]
*$py.class

# ----------------------------------------------------------
# Virtual Environment
# ----------------------------------------------------------

venv/
.venv/
env/
ENV/

# ----------------------------------------------------------
# Distribution / Packaging
# ----------------------------------------------------------

build/
dist/
downloads/
eggs/
.eggs/
*.egg-info/
*.egg

# ----------------------------------------------------------
# Flask
# ----------------------------------------------------------

instance/
.webassets-cache/

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------

*.log
logs/
*.out

# ----------------------------------------------------------
# Test / Coverage
# ----------------------------------------------------------

.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# ----------------------------------------------------------
# VS Code
# ----------------------------------------------------------

.vscode/

# ----------------------------------------------------------
# JetBrains
# ----------------------------------------------------------

.idea/

# ----------------------------------------------------------
# OS Files
# ----------------------------------------------------------

.DS_Store
Thumbs.db
desktop.ini

# ----------------------------------------------------------
# Python Environment Files
# ----------------------------------------------------------

.python-version

# ----------------------------------------------------------
# Cache
# ----------------------------------------------------------

.cache/
.mypy_cache/
.ruff_cache/

# ----------------------------------------------------------
# Generated Output Files
# ----------------------------------------------------------

output/*.json
output/*.csv
output/*.xlsx
output/*.pdf
output/*.txt

# Keep output folder
!output/.gitkeep

# ----------------------------------------------------------
# Temporary Files
# ----------------------------------------------------------

*.tmp
*.temp
*.bak
*.swp

# ----------------------------------------------------------
# Secrets / Environment
# ----------------------------------------------------------

.env
.env.*
*.pem
*.key

# ----------------------------------------------------------
# Jupyter
# ----------------------------------------------------------

.ipynb_checkpoints/

# ----------------------------------------------------------
# Keep Sample Inputs
# ----------------------------------------------------------

!sample_input/
!sample_input/*.pdf
!sample_input/*.json
!sample_input/*.csv

# ----------------------------------------------------------
# Keep Config Files
# ----------------------------------------------------------

!config/default_config.json
!config/custom_config.json

# ----------------------------------------------------------
# Keep Documentation
# ----------------------------------------------------------

!docs/
!docs/*.png
!docs/*.md

# ----------------------------------------------------------
# Keep Static Assets
# ----------------------------------------------------------

!static/images/
!static/images/*.png
!static/css/
!static/js/

# ----------------------------------------------------------
# End
# ----------------------------------------------------------